[Unit]
Description=Mini Redis TCP Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/mini-redis
Environment=PYTHONUNBUFFERED=1
Environment=MINI_REDIS_HOST=0.0.0.0
Environment=MINI_REDIS_PORT=6379
ExecStart=/usr/bin/python3 -m mini_redis.main
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
